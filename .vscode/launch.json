{
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Run Streamlit",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": ["run", "${workspaceFolder}/app.py"],
            "console": "integratedTerminal",
        },
        {
            "name": "Uvicorn (uv)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/.venv/bin/uvicorn",
            "args": ["api.app:app", "--reload", "--log-level", "debug"],
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal",
            "jinja": true
        }
    ]
}